# This env file uses @env-spec - see https://varlock.dev/env-spec for more info
# @plugin(@varlock/1password-plugin@0.3.2)
# @initOp(allowAppAuth=true)

OP_LOCATION=exec('which op')

# npm publish auth token, resolved from 1Password at run time.
# Consumed by .npmrc as //registry.npmjs.org/:_authToken=${NPM_TOKEN}
# @required @sensitive
NPM_TOKEN=op(op://Private/NPMJS_PUBLISHING_TOKEN/credential)
